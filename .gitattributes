# Keep source files consistent across Windows/macOS/Linux.
* text=auto
*.py text eol=lf
*.md text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.txt text eol=lf
*.csv text eol=lf
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.mp4 binary
*.zip binary
*.safetensors filter=lfs diff=lfs merge=lfs -text
*.bin filter=lfs diff=lfs merge=lfs -text
*.pt filter=lfs diff=lfs merge=lfs -text
*.pth filter=lfs diff=lfs merge=lfs -text
*.ckpt filter=lfs diff=lfs merge=lfs -text
