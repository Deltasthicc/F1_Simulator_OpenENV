# Copy this file to .env and fill in your secrets.
# .env is gitignored.

# Hugging Face write token (required for push to Hub and gated model access)
HF_TOKEN=hf_your_token_here

# Optional: route inference through a Docker container instead of local uvicorn
# IMAGE_NAME=ghcr.io/deltasthicc/f1-strategist:latest

# Optional: enable the Gradio web interface at /web
ENABLE_WEB_INTERFACE=1

# Optional: override default port for local dev
# F1_STRATEGIST_PORT=8000

# Optional: weights & biases project (training observability)
# WANDB_PROJECT=f1-strategist
# WANDB_API_KEY=...
