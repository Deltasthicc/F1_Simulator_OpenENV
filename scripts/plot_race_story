"""Render the headline 'race story' chart.

For a given task + seed, runs both untrained and trained policies and produces
a single PNG with two columns (BEFORE / AFTER) showing:
    - position over lap (line plot, ego vs opponents)
    - tyre health over lap
    - per-dimension final score breakdown (radar)
    - key strategic events marked (pit stops, weather changes, SC)

This is the chart that beats GIFs at telling the "trained makes better
decisions" story — judges and blog readers can see at a glance:
    1. Trained ego rises through the field (line goes up)
    2. Untrained ego stays on slicks past the rain (tyre health crashes)
    3. Trained scores higher on every dimension

Usage:
    python scripts/plot_race_story.py --task weather_roulette --seed 7
    python scripts/plot_race_story.py --output results/race_story.png
"""

from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(REPO_ROOT))


def main() -> None:
    parser = argparse.ArgumentParser()
    parser.add_argument("--task", default="weather_roulette")
    parser.add_argument("--seed", type=int, default=7)
    parser.add_argument("--output", default="results/race_story.png")
    args = parser.parse_args()

    untrained_trace, untrained_score = _run_and_capture(args.task, args.seed, "untrained")
    trained_trace, trained_score = _run_and_capture(args.task, args.seed, "trained")

    print(f"task={args.task} seed={args.seed}")
    print(f"  untrained final score: {untrained_score:.3f}")
    print(f"  trained   final score: {trained_score:.3f}")
    print(f"  Δ = {trained_score - untrained_score:+.3f}")

    _build_race_story_chart(
        args.task, args.seed,
        untrained_trace, untrained_score,
        trained_trace, trained_score,
        Path(args.output),
    )
    print(f"wrote {args.output}")


def _run_and_capture(task: str, seed: int, mode: str):
    """Run a rollout, return (frames_jsonl_list, final_score)."""
    from rollout import run_rollout

    score, jsonl_path = run_rollout(
        model="heuristic", task=task, seed=seed,
        mode=mode, render=False, verbose=False,
    )
    frames = []
    with Path(jsonl_path).open("r", encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            if line:
                frames.append(json.loads(line))
    return frames, float(score)


def _build_race_story_chart(task, seed, untrained_frames, untrained_score,
                            trained_frames, trained_score, output: Path):
    import matplotlib.pyplot as plt
    import matplotlib.patches as mpatches
    import numpy as np

    fig = plt.figure(figsize=(15, 10), dpi=130)
    fig.patch.set_facecolor("white")

    # 2 cols (untrained, trained) × 3 rows (position, tyre+events, score breakdown)
    gs = fig.add_gridspec(
        3, 2,
        height_ratios=[2.4, 1.6, 1.8],
        hspace=0.45, wspace=0.18,
        left=0.06, right=0.97, top=0.91, bottom=0.06,
    )

    # Headline title
    delta = trained_score - untrained_score
    fig.suptitle(
        f"Race story — {task.replace('_', ' ')}  (seed {seed})",
        fontsize=17, fontweight="bold", y=0.985,
    )
    fig.text(
        0.5, 0.945,
        f"Untrained: {untrained_score:.3f}    →    "
        f"Trained: {trained_score:.3f}    "
        f"(Δ {delta:+.3f})",
        ha="center", fontsize=13, fontweight="bold",
        color="#1a8754" if delta > 0 else "#c1121f",
    )

    # ─── Row 1: position over time ───────────────────────────────────
    for col, (frames, label, color) in enumerate([
        (untrained_frames, "BEFORE — untrained Qwen", "#ef8a17"),
        (trained_frames, "AFTER — GRPO-trained", "#1a8754"),
    ]):
        ax = fig.add_subplot(gs[0, col])
        _plot_positions(ax, frames, label, color)

    # ─── Row 2: tyre health + key events ─────────────────────────────
    for col, frames in enumerate([untrained_frames, trained_frames]):
        ax = fig.add_subplot(gs[1, col])
        _plot_tyre_and_events(ax, frames)

    # ─── Row 3: score breakdown bar chart ────────────────────────────
    ax_score = fig.add_subplot(gs[2, :])
    _plot_score_breakdown(ax_score, untrained_frames, trained_frames,
                          untrained_score, trained_score)

    output.parent.mkdir(parents=True, exist_ok=True)
    fig.savefig(output, dpi=130, bbox_inches="tight")
    plt.close(fig)


def _plot_positions(ax, frames, title, accent_color):
    """Position over lap, ego in bold, opponents faded."""
    laps = []
    ego_positions = []
    opp_positions: dict[int, list[tuple[int, int]]] = {}
    for f in frames:
        obs = f.get("observation", f)
        lap = int(obs.get("current_lap", 0))
        ego_p = int(obs.get("ego_position", 0))
        if ego_p > 0:
            laps.append(lap)
            ego_positions.append(ego_p)
        for opp in obs.get("opponents", []):
            try:
                num = int(opp.get("driver_number", 0))
                p = int(opp.get("position", 0))
            except (TypeError, ValueError):
                continue
            if p > 0:
                opp_positions.setdefault(num, []).append((lap, p))

    # Draw opponents as faded grey lines
    for num, points in opp_positions.items():
        if len(points) < 2:
            continue
        xs = [p[0] for p in points]
        ys = [p[1] for p in points]
        ax.plot(xs, ys, color="#c5c5c5", linewidth=1.2, alpha=0.7, zorder=2)

    # Ego in bold accent colour
    if laps:
        ax.plot(laps, ego_positions, color=accent_color, linewidth=3.0,
                marker="o", markersize=6, zorder=5,
                label="EGO", markerfacecolor=accent_color,
                markeredgecolor="white", markeredgewidth=1.0)

        # Annotate start and end positions
        ax.annotate(f"start P{ego_positions[0]}",
                    xy=(laps[0], ego_positions[0]),
                    xytext=(laps[0] + 0.3, ego_positions[0] + 0.4),
                    fontsize=9, fontweight="bold", color=accent_color)
        ax.annotate(f"finish P{ego_positions[-1]}",
                    xy=(laps[-1], ego_positions[-1]),
                    xytext=(laps[-1] - 1.2, ego_positions[-1] - 0.5),
                    fontsize=9, fontweight="bold", color=accent_color)

    # Pit stops as red triangles
    pit_laps = []
    for f in frames:
        obs = f.get("observation", f)
        msg = str(obs.get("message", "")).lower()
        act = str(f.get("action", "")).lower()
        if msg.startswith("box") or "pit_now" in act:
            pit_laps.append(int(obs.get("current_lap", 0)))
    if pit_laps:
        for pl in pit_laps:
            ax.axvline(pl, color="#c1121f", linestyle="--",
                       linewidth=1.2, alpha=0.45, zorder=1)
        ax.scatter(pit_laps, [0.5] * len(pit_laps),
                   marker="v", color="#c1121f", s=80, zorder=6,
                   label="pit stop")

    ax.set_title(title, fontsize=12, fontweight="bold", pad=8, color=accent_color)
    ax.set_xlabel("Lap", fontsize=10)
    ax.set_ylabel("Race position (1 = leader)", fontsize=10)
    ax.invert_yaxis()  # P1 at top
    ax.grid(True, alpha=0.3)
    ax.set_axisbelow(True)
    if laps:
        ax.set_xlim(0, max(laps) + 1)
    ax.set_ylim(7, 0)
    ax.legend(loc="lower right", fontsize=9)


def _plot_tyre_and_events(ax, frames):
    """Tyre health % over lap with weather rain band + compound stints."""
    laps = []
    healths = []
    compounds = []
    rains = []
    for f in frames:
        obs = f.get("observation", f)
        laps.append(int(obs.get("current_lap", 0)))
        healths.append(float(obs.get("ego_tyre_health_pct", 100.0)))
        compounds.append(obs.get("ego_tyre_compound", "medium"))
        wx = obs.get("weather_current", {}) or {}
        rains.append(float(wx.get("rain_intensity", 0.0) or 0.0))

    # Background: rain intensity as blue band height
    if rains:
        # Per-lap rectangles
        for lap, rain in zip(laps, rains):
            if rain > 0.05:
                ax.axvspan(lap - 0.5, lap + 0.5,
                           color="#003e8a", alpha=min(0.35, rain * 0.4),
                           zorder=1)

    # Tyre health line
    if laps:
        ax.plot(laps, healths, color="#1a1a1a", linewidth=2.4, zorder=4)

    # Compound stint colour bands at bottom of plot
    if laps:
        compound_colors = {
            "soft": "#e10600", "medium": "#ffd60a", "hard": "#cccccc",
            "inter": "#1a8754", "wet": "#003e8a",
        }
        prev_comp = compounds[0]
        start_lap = laps[0]
        for lap, comp in zip(laps, compounds):
            if comp != prev_comp:
                ax.axvspan(start_lap - 0.5, lap - 0.5,
                           ymin=0, ymax=0.08,
                           color=compound_colors.get(prev_comp, "#888"),
                           zorder=2)
                start_lap = lap
                prev_comp = comp
        ax.axvspan(start_lap - 0.5, laps[-1] + 0.5,
                   ymin=0, ymax=0.08,
                   color=compound_colors.get(prev_comp, "#888"), zorder=2)

    ax.set_xlabel("Lap", fontsize=10)
    ax.set_ylabel("Tyre health (%)", fontsize=10)
    ax.set_ylim(0, 105)
    if laps:
        ax.set_xlim(0, max(laps) + 1)
    ax.grid(True, alpha=0.3)
    ax.axhline(40, color="#c1121f", linestyle=":", linewidth=1, alpha=0.6)
    ax.text(0.5, 42, "danger zone", fontsize=8, color="#c1121f", style="italic")


def _plot_score_breakdown(ax, untrained_frames, trained_frames,
                          untrained_score, trained_score):
    """Six-dimension score bars side-by-side."""
    untrained_dims = _final_dims(untrained_frames)
    trained_dims = _final_dims(trained_frames)

    dims = [
        "race_result", "strategic_decisions", "tyre_management",
        "fuel_management", "comms_quality", "operational_efficiency",
    ]
    nice = {
        "race_result": "Race result",
        "strategic_decisions": "Strategy",
        "tyre_management": "Tyres",
        "fuel_management": "Fuel",
        "comms_quality": "Comms",
        "operational_efficiency": "Operations",
    }
    n = len(dims)
    x = list(range(n))
    width = 0.38
    untrained_vals = [float(untrained_dims.get(d, 0.0)) for d in dims]
    trained_vals = [float(trained_dims.get(d, 0.0)) for d in dims]

    ax.bar([v - width / 2 for v in x], untrained_vals, width,
           color="#ef8a17", label="untrained", edgecolor="white", linewidth=1.0)
    ax.bar([v + width / 2 for v in x], trained_vals, width,
           color="#1a8754", label="trained", edgecolor="white", linewidth=1.0)

    for i, (u, t) in enumerate(zip(untrained_vals, trained_vals)):
        ax.text(i - width / 2, u + 0.02, f"{u:.2f}",
                ha="center", fontsize=8.5, color="#ef8a17", fontweight="bold")
        ax.text(i + width / 2, t + 0.02, f"{t:.2f}",
                ha="center", fontsize=8.5, color="#1a8754", fontweight="bold")

    ax.set_xticks(x)
    ax.set_xticklabels([nice[d] for d in dims], fontsize=10)
    ax.set_ylim(0, 1.18)
    ax.set_yticks([0.0, 0.25, 0.5, 0.75, 1.0])
    ax.set_ylabel("Dimension score (0–1)", fontsize=10)
    ax.set_title("Six-dimension reward breakdown",
                 fontsize=12, fontweight="bold", pad=8)
    ax.grid(axis="y", alpha=0.3)
    ax.set_axisbelow(True)
    ax.legend(loc="upper right", fontsize=10, frameon=True)


def _final_dims(frames):
    """Pull the final multi_objective_scores dict from the last frame."""
    for f in reversed(frames):
        obs = f.get("observation", f)
        scores = obs.get("multi_objective_scores")
        if scores:
            return scores
    return {}


if __name__ == "__main__":
    main()